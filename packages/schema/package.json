{
    "name": "@party-stack/schema",
    "version": "0.1.1",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./generate": {
            "types": "./lib/generate/index.d.ts",
            "default": "./lib/generate/index.js"
        },
        "./values": {
            "types": "./lib/utils/values.d.ts"
        }
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "bootstrap": "tsx src/generate/generate.ts --schema ./src/ir/schema.ts --exportName s --promoted TypeDef --outDir ./src/ir/generated",
        "build": "tsc",
        "lint": "eslint",
        "test": "vitest run"
    },
    "dependencies": {
        "@standard-schema/spec": "^1.1.0",
        "commander": "^14.0.2",
        "jiti": "^2.6.1",
        "prettier": "^3.5.3",
        "temporal-polyfill": "^0.3.0",
        "ts-morph": "^27.0.2",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@bobbyfidz/universal-build-config": "^0.1.1",
        "eslint": "^9.25.0",
        "tsx": "^4.20.6",
        "typescript": "~5.8.3",
        "vitest": "^3.1.1"
    }
}
