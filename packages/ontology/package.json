{
    "name": "@party-stack/ontology",
    "version": "0.0.0",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "bootstrap": "tsx ../schema/src/generate/generate.ts --schema ./src/ir/schema.ts --exportName o --promoted TypeDef --outDir ./src/ir/generated",
        "build": "tsc",
        "generate:examples": "tsx ./src/cli/generate.ts --ontology ./src/examples/blog.ts --outDir ./src/examples/generated",
        "generate:meta": "tsx ./src/cli/generate.ts --ontology ./src/meta/ontology.ts --outDir ./src/meta/generated",
        "pull:ontology": "tsx ./src/cli/pull.ts",
        "lint": "eslint",
        "test": "vitest run"
    },
    "dependencies": {
        "@bobbyfidz/panic": "^0.1.0",
        "@party-stack/schema": "workspace:*",
        "commander": "^14.0.2",
        "jiti": "^2.6.1",
        "prettier": "^3.5.3",
        "ts-morph": "^27.0.2",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@bobbyfidz/universal-build-config": "^0.1.1",
        "@tanstack/db": "^0.5.30",
        "eslint": "^9.25.0",
        "tsx": "^4.20.6",
        "typescript": "~5.8.3",
        "vitest": "^3.1.1"
    },
    "peerDependencies": {
        "@tanstack/db": "^0.5.30"
    }
}
