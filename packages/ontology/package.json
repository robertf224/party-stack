{
    "name": "@party-stack/ontology",
    "version": "0.3.0",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./utils": {
            "types": "./lib/utils/index.d.ts",
            "default": "./lib/utils/index.js"
        },
        "./json": {
            "types": "./lib/json/index.d.ts",
            "default": "./lib/json/index.js"
        },
        "./values": {
            "types": "./lib/utils/values.d.ts"
        }
    },
    "bin": {
        "ontology": "./lib/cli/index.js"
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "bootstrap": "tsx ./src/cli/index.ts generate --ontology ./src/ir/schema.ts --outDir ./src/ir/generated",
        "build": "tsc",
        "generate:examples": "tsx ./src/cli/index.ts generate --ontology ./src/examples/blog.ts --outDir ./src/examples/generated --namespace Blog",
        "generate:meta": "tsx ./src/cli/index.ts generate --ontology ./src/meta/ontology.ts --outDir ./src/meta/generated --namespace Meta",
        "lint": "eslint",
        "ontology": "tsx ./src/cli/index.ts",
        "test": "vitest run"
    },
    "dependencies": {
        "@bobbyfidz/panic": "^0.1.0",
        "@next/env": "^16.1.6",
        "@party-stack/blobs": "workspace:*",
        "change-case": "^5.4.4",
        "commander": "^14.0.2",
        "jiti": "^2.6.1",
        "lodash-es": "^4.17.23",
        "prettier": "^3.5.3",
        "temporal-polyfill": "^0.3.0",
        "ts-morph": "^27.0.2",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@bobbyfidz/universal-build-config": "^0.1.1",
        "@tanstack/db": "^0.6.5",
        "@types/lodash-es": "^4.17.12",
        "eslint": "^9.25.0",
        "tsx": "^4.20.6",
        "typescript": "~5.8.3",
        "vitest": "^3.1.1"
    },
    "peerDependencies": {
        "@tanstack/db": "^0.6.5"
    }
}
