{
    "name": "@bobbyfidz/foundry-db",
    "version": "0.0.0",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./users": {
            "types": "./lib/users/index.d.ts",
            "default": "./lib/users/index.js"
        },
        "./objects": {
            "types": "./lib/objects/index.d.ts",
            "default": "./lib/objects/index.js"
        },
        "./ontology-metadata": {
            "types": "./lib/ontology-metadata/index.d.ts",
            "default": "./lib/ontology-metadata/index.js"
        },
        "./ontology": {
            "types": "./lib/ontology/index.d.ts",
            "default": "./lib/ontology/index.js"
        },
        "./schema": {
            "types": "./lib/schema/index.d.ts",
            "default": "./lib/schema/index.js"
        }
    },
    "bin": {
        "foundry-db": "./bin/run.js"
    },
    "files": [
        "lib",
        "bin"
    ],
    "scripts": {
        "build": "tsc",
        "lint": "eslint",
        "test": "vitest run --pass-with-no-tests",
        "test-history": "tsx src/objects/lib/getObjectEditHistory.ts"
    },
    "oclif": {
        "bin": "foundry-db",
        "commands": "./lib/cli/commands",
        "dirname": "foundry-db",
        "topicSeparator": " "
    },
    "dependencies": {
        "@bobbyfidz/local-oauth-flow": "^0.1.0",
        "@bobbyfidz/osdk-utils": "workspace:*",
        "@bobbyfidz/panic": "^0.1.0",
        "@bobbyfidz/urls": "^0.2.1",
        "@party-stack/ontology": "workspace:*",
        "@effectionx/signals": "^0.5.2",
        "@effectionx/stream-helpers": "^0.8.1",
        "@effectionx/websocket": "^2.3.2",
        "@next/env": "^16.0.3",
        "@oclif/core": "^4.8.0",
        "@osdk/foundry.admin": "^2.47.0",
        "@osdk/foundry.ontologies": "^2.49.0",
        "@osdk/shared.client.impl": "^1.5.0",
        "@osdk/shared.client2": "^1.0.0",
        "effection": "^4.0.2",
        "temporal-polyfill": "^0.3.0",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@bobbyfidz/react-build-config": "^0.1.1",
        "@tanstack/db": "^0.5.32",
        "@tanstack/query-db-collection": "^1.0.29",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.6",
        "eslint": "^9.25.0",
        "react": "^19.2.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.20.6",
        "typescript": "~5.8.3",
        "vitest": "^3.1.1"
    },
    "peerDependencies": {
        "@tanstack/db": "^0.5.32",
        "@tanstack/query-core": "^5.0.0",
        "@tanstack/query-db-collection": "^1.0.29",
        "react": "^18.0.0 || ^19.0.0"
    }
}
